                border-radius: 5px;
                margin: 2px;
            }
            QScrollBar::handle:vertical {
                background: #35506f;
                min-height: 24px;
                border-radius: 5px;
            }
            QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
                height: 0px;
